```gitignore
# ============================================================
# Python
# ============================================================

__pycache__/
*.py[cod]
*.so

# ============================================================
# Virtual Environments
# ============================================================

.venv/
venv/


# ============================================================
# Jupyter
# ============================================================

.ipynb_checkpoints/

# ============================================================
# Pytest
# ============================================================

.pytest_cache/

# ============================================================
# IDE / Editor
# ============================================================

.vscode/
.idea/

# ============================================================
# Operating System
# ============================================================

.DS_Store
Thumbs.db

# ============================================================
# Data Files
# Ignore contents, preserve directory structure
# ============================================================

data/raw/*
data/interim/*
data/processed/*

# Keep directory placeholders
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# ============================================================
# Paper-local Data
# ============================================================

papers/*/data/raw/*
papers/*/data/interim/*
papers/*/data/processed/*

!papers/*/data/raw/.gitkeep
!papers/*/data/interim/.gitkeep
!papers/*/data/processed/.gitkeep
```
